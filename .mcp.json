{
  "mcpServers": {
    "api-guidelines": {
      "type": "sse",
      "url": "https://api-mcp.bitso.io/sse"
    },
    "sonarqube": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "https://sonarqube.bitso.io"
      }
    }
  }
}